# ─── LLM provider ─────────────────────────────────────────────────────────────
# Pick ONE option. Uses LiteLLM model string format (provider/model).
#
# Option A — Claude Code (zero-config): if the `claude` CLI is installed and logged
# in, it is auto-detected and your subscription is used as the LLM. For this to work,
# leave LLM_MODEL, OPENROUTER_API_KEY, ANTHROPIC_API_KEY and LLM_API_BASE UNSET below.
# Set CLAUDE_CODE_AUTODETECT=false to turn detection off.
# CLAUDE_CODE_AUTODETECT=true

# Option B — OpenRouter (200+ models via one key). Uncomment both lines to use it
# (this takes priority over Claude Code auto-detection).
# LLM_MODEL=openrouter/openai/gpt-4o
# OPENROUTER_API_KEY=sk-or-...

# Anthropic direct (API key, not subscription)
# LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI direct
# LLM_MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-...

# Groq (fast + free tier)
# LLM_MODEL=groq/llama3-70b-8192
# GROQ_API_KEY=gsk_...

# Ollama (local, no key needed)
# LLM_MODEL=ollama/llama3
# LLM_API_BASE=http://localhost:11434

# Any OpenAI-compatible endpoint
# LLM_MODEL=openai/your-model-name
# LLM_API_BASE=https://your-endpoint/v1
# LLM_API_KEY=your-key

# Cloud provider — selects the active provider (aws | azure | gcp). Default: aws.
# Azure and GCP are stubs; only aws is implemented today.
# CLOUD_PROVIDER=aws

# AWS (use IAM role or explicit keys)
AWS_REGION=us-east-1
AWS_PROFILE=devops-agent-readonly   # optional — use named profile (local dev)
# AWS_ACCESS_KEY_ID=AKIA...         # use explicit keys instead (Railway, Docker, CI)
# AWS_SECRET_ACCESS_KEY=...
# CREDENTIALS_ENCRYPTION_KEY=        # Fernet key to decrypt cloud_accounts secrets (multi-account);
                                     # unset = env/profile creds only. Gen: Fernet.generate_key().decode()

# Agent behavior
MAX_TOOL_CALLS=20
INVESTIGATION_TIMEOUT=120
LOG_LEVEL=DEBUG                  # DEBUG | INFO | WARNING | ERROR
LOG_CONSOLE_ENABLED=true        # false → suppress all console output (e.g. log to file only)
LOG_CONSOLE_COLORIZE=true       # false → strip ANSI colour codes (CI pipelines, Docker logs)
# TOOL_RESPONSE_MAX_CHARS=40000  # cap large tool responses before they reach the LLM; 0 = disabled
# SUMMARIZATION_ENABLED=true
# SUMMARIZATION_THRESHOLD_CHARS=60000  # compact session when total message chars exceed this (~15K tokens)
# SUMMARIZATION_KEEP_CHARS=20000       # preserve this many recent chars intact (~5K tokens)

# Storage backend — uncomment exactly ONE block below:
#
# Option 1 — Memory (default): no persistence, zero config, dashboard counts only
CHECKPOINT_BACKEND=memory

# Option 2 — SQLite: local file, zero external deps, full dashboard (recommended for local dev)
# CHECKPOINT_BACKEND=sqlite
# SQLITE_PATH=./data/agent.db

# Option 3 — PostgreSQL: full production persistence, full dashboard
# CHECKPOINT_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/opendevops

# Auth — leave JWT_SECRET unset to disable auth entirely
# JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRE_MINUTES=1440

# Slack — leave unset to disable notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Telegram — leave unset to disable notifications
# TELEGRAM_BOT_TOKEN=123456:ABC-...   # from @BotFather
# TELEGRAM_CHAT_ID=-100123456789      # group/channel ID (negative = group)

# Proactive polling — set POLL_INTERVAL_SECONDS>0 to enable
# POLL_INTERVAL_SECONDS=300       # how often to check (seconds); 0 = disabled; 20 for dev testing
# POLL_ERROR_THRESHOLD=5.0        # Lambda error rate % that triggers an investigation
# POLL_REINVESTIGATE_HOURS=1      # don't re-investigate the same alarm within N hours

# Event-driven detection — configure SQS via Settings → AWS Configuration after login
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/opendevops
# EVENT_CONSUMER_ENABLED=false
