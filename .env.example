# LLM — use LiteLLM model string format (provider/model)
# OpenRouter (default — 200+ models via one key)
LLM_MODEL=openrouter/openai/gpt-4o
OPENROUTER_API_KEY=sk-or-...

# Anthropic direct
# LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI direct
# LLM_MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-...

# Groq (fast + free tier)
# LLM_MODEL=groq/llama3-70b-8192
# GROQ_API_KEY=gsk_...

# Ollama (local, no key needed)
# LLM_MODEL=ollama/llama3
# LLM_API_BASE=http://localhost:11434

# Any OpenAI-compatible endpoint
# LLM_MODEL=openai/your-model-name
# LLM_API_BASE=https://your-endpoint/v1
# LLM_API_KEY=your-key

# AWS (use IAM role or explicit keys)
AWS_REGION=us-east-1
AWS_PROFILE=devops-agent-readonly   # optional

# Agent behavior
MAX_TOOL_CALLS=20
INVESTIGATION_TIMEOUT=120
LOG_LEVEL=INFO

# Storage backend — uncomment exactly ONE block below:
#
# Option 1 — Memory (default): no persistence, zero config, dashboard counts only
CHECKPOINT_BACKEND=memory

# Option 2 — SQLite: local file, zero external deps, full dashboard (recommended for local dev)
# CHECKPOINT_BACKEND=sqlite
# SQLITE_PATH=./data/agent.db

# Option 3 — PostgreSQL: full production persistence, full dashboard
# CHECKPOINT_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/opendevops

# Slack — leave unset to disable notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Proactive polling — set POLL_INTERVAL_MINUTES>0 to enable
# POLL_INTERVAL_MINUTES=5         # how often to check (minutes); 0 = disabled
# POLL_ERROR_THRESHOLD=5.0        # Lambda error rate % that triggers an investigation
# POLL_REINVESTIGATE_HOURS=1      # don't re-investigate the same alarm within N hours
